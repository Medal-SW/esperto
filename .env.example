POSTGRES_USER=esperto
POSTGRES_PASSWORD=esperto123
POSTGRES_DB=esperto
JWT_SECRET=change-me-in-production

MAIL_USERNAME=email@gmail.com
MAIL_PASSWORD=yourpassword
MAIL_FROM=email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

FRONTEND_URL=frontend_url

# Google OAuth Client ID (login com Google). No Google Cloud Console, as
# "Authorized JavaScript origins" do client devem incluir http://localhost:5173
# (dev) e a origem de produção. Não é necessário redirect URI (fluxo de botão GIS).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Production: use strong values for all fields above.
# Dev defaults are baked into docker-compose.yml, so this file is optional for dev.
